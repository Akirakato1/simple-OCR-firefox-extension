{
  "manifest_version": 2,
  "name": "Tab OCR Translate",
  "version": "0.1.0",
  "description": "Select a browser-tab region, OCR it with OCR.space, translate it with Google Translate, and manage results in an in-tab panel.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "https://api.ocr.space/*",
    "https://translation.googleapis.com/*"
  ],
  "background": {
    "scripts": ["src/background/background.js"],
    "persistent": false,
    "type": "module"
  },
  "icons": {
    "48": "icons/ocr-o.svg",
    "96": "icons/ocr-o.svg"
  },
  "browser_action": {
    "default_title": "Toggle OCR Translate Panel",
    "default_icon": {
      "16": "icons/ocr-o.svg",
      "32": "icons/ocr-o.svg",
      "48": "icons/ocr-o.svg"
    },
    "browser_style": true
  },
  "web_accessible_resources": [
    "src/sidebar/sidebar.html",
    "src/sidebar/sidebar.css",
    "src/sidebar/sidebar.js",
    "src/sidebar/selection.js",
    "src/sidebar/theme-bootstrap.js",
    "src/shared/constants.js",
    "src/shared/history.js",
    "src/shared/languages.js",
    "src/shared/settings.js",
    "src/shared/theme.js"
  ],
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "commands": {
    "start-ocr-capture": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Select a tab region for OCR and translation"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tab-ocr-translate@example.local",
      "strict_min_version": "109.0"
    }
  }
}
